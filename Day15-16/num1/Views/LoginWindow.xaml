<Window x:Class="num1.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:num1.ViewModels"
        Title="Авторизация" Height="320" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📋 Task Manager" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Имя пользователя:" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="2" x:Name="UsernameBox" 
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Height="30"/>

        <TextBlock Grid.Row="3" Text="Пароль:" FontWeight="Bold" Margin="0,5"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox" Margin="0,5" Height="30"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Войти" Width="100" Margin="5" 
                    Command="{Binding LoginCommand}" 
                    Background="#FF4CAF50" Foreground="White"
                    Padding="10,5"/>
            <Button Content="Регистрация" Width="100" Margin="5" 
                    Command="{Binding RegisterCommand}"
                    Background="#FF2196F3" Foreground="White"
                    Padding="10,5"/>
        </StackPanel>

        <TextBlock Grid.Row="6" Text="{Binding LoadingMessage}" 
                   HorizontalAlignment="Center" Margin="0,10"
                   Foreground="Blue"/>
    </Grid>
</Window>