<Window x:Class="num1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:num1"
        Title="Task Manager" Height="500" Width="750"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <local:TaskManagerViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddTaskCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditTaskCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteTaskCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding ChangeStatusCommand}"/>
    </Window.InputBindings>



    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Менеджер задач" 
                   FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <Button Content="➕ Добавить" Width="130" Margin="2" 
                    Command="{Binding AddTaskCommand}"/>
            <Button Content="✏️ Редактировать" Width="130" Margin="2" 
                    Command="{Binding EditTaskCommand}"/>
            <Button Content="❌ Удалить" Width="130" Margin="2" 
                    Command="{Binding DeleteTaskCommand}"/>
            <Button Content="🔄 Сменить статус" Width="130" Margin="2" 
                    Command="{Binding ChangeStatusCommand}"/>

            <Separator Width="20" Visibility="Hidden"/>

            <TextBlock Text="Фильтр:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <ComboBox ItemsSource="{Binding FilterOptions}" 
                      SelectedItem="{Binding StatusFilter}"
                      Width="100" VerticalAlignment="Center"/>
        </WrapPanel>

        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Tasks}" 
                  SelectedItem="{Binding SelectedTask}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  Margin="0,5">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Width="150" 
                                    Binding="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Описание" Width="250" 
                                    Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Срок" Width="100" 
                                    Binding="{Binding Deadline, StringFormat=dd.MM.yyyy, Mode=TwoWay}"/>
                <DataGridTextColumn Header="Статус" Width="100" 
                                    Binding="{Binding StatusText, Mode=OneWay}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding Tasks.Count, StringFormat='Всего задач: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedTask.Title, StringFormat='Выбрано: {0}', FallbackValue='Ничего не выбрано'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>