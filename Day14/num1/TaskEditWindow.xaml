<Window x:Class="num1.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача" Height="350" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Название:" FontWeight="Bold"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TitleBox" Margin="5" Height="30"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Описание:" FontWeight="Bold"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="DescriptionBox" 
                 Margin="5" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Срок:" FontWeight="Bold"/>
        <DatePicker Grid.Row="2" Grid.Column="1" x:Name="DeadlinePicker" 
                    Margin="5" Height="30" SelectedDateFormat="Short"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Статус:" FontWeight="Bold"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="StatusBox" Margin="5" Height="30">
            <ComboBoxItem Content="Ожидание" Tag="Ожидание"/>
            <ComboBoxItem Content="В работе" Tag="ВРаботе"/>
            <ComboBoxItem Content="Выполнено" Tag="Выполнено"/>
        </ComboBox>

        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="5,20,5,5">
            <Button x:Name="SaveButton" Content="Сохранить" Width="80" 
                    Margin="5" Click="SaveButton_Click"
                    Background="#4CAF50" Foreground="White"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="80" 
                    Margin="5" Click="CancelButton_Click"
                    Background="#9E9E9E" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>