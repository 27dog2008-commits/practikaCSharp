<Window x:Class="num1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Стиль для задачи с подсветкой -->
        <Style x:Key="TaskBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="10"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Выполнено">
                    <Setter Property="Background" Value="#FFF0FFF0"/>
                    <Setter Property="BorderBrush" Value="#FF4CAF50"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="ВРаботе">
                    <Setter Property="Background" Value="#FFE3F2FD"/>
                    <Setter Property="BorderBrush" Value="#FF2196F3"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Ожидание">
                    <Setter Property="Background" Value="#FFFFF3E0"/>
                    <Setter Property="BorderBrush" Value="#FFFF9800"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- DataTemplate для задачи -->
        <DataTemplate x:Key="TaskItemTemplate">
            <Border x:Name="TaskBorder"
                    Style="{StaticResource TaskBorderStyle}"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform/>
                </Border.RenderTransform>
                <Border.Effect>
                    <BlurEffect Radius="0"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Description}" Foreground="#FF666666" Grid.Row="1" Margin="0,0,0,5" TextWrapping="Wrap"/>

                    <WrapPanel Grid.Row="2">
                        <TextBlock Text="📅 Срок: " Foreground="#FF666666"/>
                        <TextBlock Text="{Binding Deadline, StringFormat=dd.MM.yyyy}" Foreground="#FF2196F3"/>
                        <TextBlock Text=" | 🏷 " Foreground="#FF666666" Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding Category.Name}"/>
                        <TextBlock Text=" | " Foreground="#FF666666"/>
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"/>
                        <TextBlock Text=" | 📅 Создано: " Foreground="#FF666666" Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding CreatedDate, StringFormat=dd.MM.yyyy}" Foreground="#FF666666"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Стиль для ListBoxItem -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Margin="5">
                            <ContentPresenter x:Name="ContentPresenter"
                                            Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFE3F2FD"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FF2196F3"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFF5F5F5"/>
                                <Setter TargetName="Border" Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddTaskCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditTaskCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteTaskCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding ChangeStatusCommand}"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding LoadTasksCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF2196F3" Padding="15">
            <TextBlock Text="📋 Менеджер задач" FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10">
            <Button Content="➕ Добавить" Width="100" Margin="2" 
                    Command="{Binding AddTaskCommand}" Background="#FF4CAF50" Foreground="White"
                    Cursor="Hand"/>
            <Button Content="✏️ Изменить" Width="100" Margin="2" 
                    Command="{Binding EditTaskCommand}" Background="#FFFF9800" Foreground="White"
                    Cursor="Hand"/>
            <Button Content="❌ Удалить" Width="100" Margin="2" 
                    Command="{Binding DeleteTaskCommand}" Background="#FFF44336" Foreground="White"
                    Cursor="Hand"/>
            <Button Content="🔄 Статус" Width="100" Margin="2" 
                    Command="{Binding ChangeStatusCommand}" Background="#FF2196F3" Foreground="White"
                    Cursor="Hand"/>
            <Button Content="⟳ Обновить" Width="100" Margin="2" 
                    Command="{Binding LoadTasksCommand}" Background="#FF9E9E9E" Foreground="White"
                    Cursor="Hand"/>

            <TextBlock Text="Фильтр:" VerticalAlignment="Center" Margin="20,0,5,0"/>
            <ComboBox ItemsSource="{Binding FilterOptions}" 
                      SelectedItem="{Binding StatusFilter}" Width="100"/>

            <!-- Индикатор загрузки -->
            <StackPanel Orientation="Horizontal" Margin="20,0,0,0" 
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <ProgressBar Width="20" Height="20" IsIndeterminate="True" 
                           Foreground="#FF2196F3" Margin="0,0,5,0"/>
                <TextBlock Text="Загрузка..." VerticalAlignment="Center" Foreground="#FF2196F3"/>
            </StackPanel>
        </WrapPanel>

        <!-- Список задач -->
        <ListBox x:Name="TaskListBox"
                 Grid.Row="2" 
                 ItemsSource="{Binding Tasks}" 
                 SelectedItem="{Binding SelectedTask}"
                 ItemTemplate="{StaticResource TaskItemTemplate}"
                 AllowDrop="True"
                 Drop="TaskListBox_Drop"
                 PreviewMouseLeftButtonDown="TaskListBox_PreviewMouseLeftButtonDown"
                 PreviewMouseLeftButtonUp="TaskListBox_PreviewMouseLeftButtonUp"
                 PreviewMouseMove="TaskListBox_PreviewMouseMove"
                 Margin="10"
                 BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform/>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Статусбар -->
        <StatusBar Grid.Row="3" Background="#FFF0F0F0">
            <StatusBarItem>
                <TextBlock Text="{Binding Tasks.Count, StringFormat='📊 Всего задач: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedTask.Title, StringFormat='✓ Выбрано: {0}', FallbackValue='✓ Ничего не выбрано'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding LoadingMessage}" Foreground="Green"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>