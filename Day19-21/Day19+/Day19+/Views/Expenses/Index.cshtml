@model IEnumerable<ExpenseTracker.Models.Expense>

<h2>Учёт личных расходов</h2>

<!-- Форма добавления -->
<div class="card p-3 mb-4">
    <h4>Добавить новый расход</h4>
    <form asp-action="Create" method="post" class="row g-3">
        <div class="col-md-3">
            <input name="Amount" type="number" step="0.01" class="form-control" placeholder="Сумма" required />
        </div>
        <div class="col-md-3">
            <input name="Category" type="text" class="form-control" placeholder="Категория" required />
        </div>
        <div class="col-md-3">
            <input name="Date" type="date" class="form-control" required />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Добавить</button>
        </div>
    </form>
</div>

<hr />

<!-- Фильтр и Таблица -->
<h3>Список расходов @(ViewBag.CurrentCategory != null ? $"- {ViewBag.CurrentCategory}" : "")</h3>

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Дата</th>
            <th>Категория</th>
            <th>Сумма</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToShortDateString()</td>
                <td>@item.Category</td>
                <td>@item.Amount.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>